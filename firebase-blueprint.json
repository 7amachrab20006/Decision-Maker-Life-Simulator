{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Information about a registered user",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "totalQuizzes": { "type": "integer" },
        "avgScore": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastActivity": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "email", "createdAt"]
    },
    "ScoreAttempt": {
      "title": "Quiz Attempt",
      "description": "Result of a completed quiz",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "score": { "type": "integer" },
        "total": { "type": "integer" },
        "difficulty": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "category", "score", "total", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/scores/{scoreId}": {
      "schema": "ScoreAttempt",
      "description": "Quiz results per attempt"
    }
  }
}
